# Database
DATABASE_URL=postgresql://aria:aria@localhost:5432/aria_dev

# JWT (RS256) — generate: bash scripts/generate-keys.sh
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Middleware
COOKIE_SECRET=change-this-to-a-random-string-of-at-least-32-chars
MIDDLEWARE_PORT=3001
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# GitHub OAuth
# Create at https://github.com/settings/developers
# Callback: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Web
NEXT_PUBLIC_MIDDLEWARE_URL=http://localhost:3001

# Backend
BACKEND_URL=http://localhost:8080

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
