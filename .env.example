# ============================================================
# ARIA V1 — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to git
# ============================================================

# ----- Database (Supabase Postgres) -------------------------
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/[DB_NAME]
DATABASE_DIRECT_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/[DB_NAME]

# ----- Auth (JWT RS256 — generate with scripts/generate-keys.sh) -----
# Base64-encoded RSA private key (used by middleware to SIGN tokens)
JWT_PRIVATE_KEY=
# Base64-encoded RSA public key (used by middleware + backend to VERIFY tokens)
JWT_PUBLIC_KEY=
# Access token expiry
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token expiry
JWT_REFRESH_EXPIRES_IN=7d
# Refresh token cookie secret (random 64-char string)
COOKIE_SECRET=

# ----- GitHub OAuth App -------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/auth/github/callback

# ----- Ollama (local LLM) -----------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ----- Jira (optional) --------------------------------------
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_USER_EMAIL=

# ----- App URLs ---------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
MIDDLEWARE_PORT=3001
BACKEND_PORT=8080

# ----- Security ---------------------------------------------
# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
# Rate limit: max requests per window
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ----- Node env ---------------------------------------------
NODE_ENV=development
