# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/aria_dev

# ── JWT (RSA key pair — generate with scripts/generate-keys.sh) ──
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Middleware ────────────────────────────────────────────
COOKIE_SECRET=replace-me-with-a-32-char-minimum-secret
MIDDLEWARE_PORT=3001
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ── GitHub OAuth (create at https://github.com/settings/applications/new) ──
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ── Backend (Spring Boot) ─────────────────────────────────
BACKEND_URL=http://localhost:8080

# ── Ollama ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── Next.js web app ──────────────────────────────────────
NEXT_PUBLIC_MIDDLEWARE_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
