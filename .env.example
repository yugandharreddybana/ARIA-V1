# ARIA-V1 — example environment. Copy to .env.local and fill in.

# ── Postgres ──────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aria_dev
POSTGRES_USER=aria
POSTGRES_PASSWORD=aria
DATABASE_URL=postgresql://aria:aria@localhost:5432/aria_dev

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── JWT (RS256) — generate via: bash scripts/generate-keys.sh ─────────
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Middleware ────────────────────────────────────────────────────────
COOKIE_SECRET=change-this-to-a-random-string-of-at-least-32-chars
MIDDLEWARE_PORT=3001
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ── GitHub OAuth (Create at https://github.com/settings/developers) ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ── Web ───────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_MIDDLEWARE_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── Backend (Spring) ──────────────────────────────────────────────────
BACKEND_PORT=8080
BACKEND_URL=http://localhost:8080

# ── Ollama (local LLM) ────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Anthropic (Claude) — disabled until key granted ───────────────────
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_HIGH_STAKES_MODEL=claude-opus-4-7

# ── Token Gateway (Sprint 5 §18H) ─────────────────────────────────────
MAX_SESSION_TOKEN_BUDGET=500000
TOKEN_BUDGET_WARN_RATIO=0.80
TOKEN_BUDGET_HARD_RATIO=0.95
MAX_QUEUE_DEPTH=50
