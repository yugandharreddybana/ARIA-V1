{
  "name": "aria-v1",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "dev:reset": "bash scripts/dev-down.sh --wipe && bash scripts/dev-up.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "test:e2e": "pnpm -F @aria/e2e test",
    "knowledge-audit": "pnpm -F @aria/middleware exec tsx ../../scripts/knowledge-audit.ts",
    "model-transfer": "pnpm -F @aria/middleware exec tsx ../../scripts/model-transfer.ts",
    "anti-slop": "pnpm -F @aria/middleware exec tsx ../../tools/anti-slop-gate.ts",
    "anti-test-dodging": "pnpm -F @aria/middleware exec tsx ../../tools/anti-test-dodging.ts"
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "prettier": "^3.3.0"
  }
}
