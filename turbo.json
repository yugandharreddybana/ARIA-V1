{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_PRIVATE_KEY",
    "JWT_PUBLIC_KEY",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "OLLAMA_BASE_URL",
    "OLLAMA_DEFAULT_MODEL",
    "OLLAMA_EMBEDDING_MODEL",
    "ANTHROPIC_ENABLED",
    "ANTHROPIC_API_KEY",
    "ANTHROPIC_DEFAULT_MODEL",
    "ANTHROPIC_HIGH_STAKES_MODEL",
    "MAX_SESSION_TOKEN_BUDGET",
    "TOKEN_BUDGET_WARN_RATIO",
    "TOKEN_BUDGET_HARD_RATIO",
    "MAX_QUEUE_DEPTH",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_MIDDLEWARE_URL",
    "NEXT_PUBLIC_WS_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
